---
import type { CollectionEntry } from 'astro:content';

interface Props {
	project: CollectionEntry<'work'> | CollectionEntry<'blog'>;
}

const { data, id, collection } = Astro.props.project;
---

{collection === 'blog' ? (
	<a class="list-card" href={`/${collection}/${id}`}>
		{data.img && (
			<div class="img-wrapper">
				<img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />
			</div>
		)}
		<div class="info">
			<span class="title">{data.title}</span>
			{data.description && <p class="description">{data.description}</p>}
		</div>
	</a>
) : (
	<a class="card" href={`/${collection}/${id}`}>
		<span class="title">{data.title}</span>
		{data.img && <img src={data.img} alt={data.img_alt || ''} loading="lazy" decoding="async" />}
	</a>
)}

<style>
	/* Work card */
	.card {
		display: grid;
		grid-template: auto 1fr / auto 1fr;
		height: 11rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		overflow: hidden;
		box-shadow: var(--shadow-sm);
		text-decoration: none;
		font-family: var(--font-brand);
		font-size: var(--text-lg);
		font-weight: 500;
		transition: box-shadow var(--theme-transition);
	}

	.card:hover {
		box-shadow: var(--shadow-md);
	}

	.card .title {
		grid-area: 1 / 1 / 2 / 2;
		z-index: 1;
		margin: 0.5rem;
		padding: 0.5rem 1rem;
		background: var(--gray-999);
		color: var(--gray-200);
		border-radius: 0.375rem;
	}

	.card img {
		grid-area: 1 / 1 / 3 / 3;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	/* Blog list card */
	.list-card {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 1.25rem;
		padding: 1rem 1.25rem;
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
		border-radius: 0.75rem;
		text-decoration: none;
		font-family: var(--font-brand);
		box-shadow: var(--shadow-sm);
		transition: box-shadow var(--theme-transition);
	}

	.list-card:hover {
		box-shadow: var(--shadow-md);
	}

	.img-wrapper {
		width: 5rem;
		height: 5rem;
		flex-shrink: 0;
		border-radius: 0.5rem;
		overflow: hidden;
	}

	.img-wrapper img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.list-card .info {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.list-card .title {
		font-size: var(--text-lg);
		font-weight: 600;
		color: var(--gray-200);
	}

	.list-card .description {
		font-size: var(--text-sm);
		color: var(--gray-400);
		font-family: var(--font-body);
		margin: 0;
		line-height: 1.5;
	}

	@media (min-width: 50em) {
		.card {
			height: 22rem;
			border-radius: 1.5rem;
		}

		.card .title {
			border-radius: 0.9375rem;
		}

		.list-card {
			padding: 1.25rem 1.75rem;
			border-radius: 1.5rem;
		}

		.img-wrapper {
			width: 6rem;
			height: 6rem;
		}

		.list-card .title {
			font-size: var(--text-xl);
		}
	}
</style>